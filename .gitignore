# Foundry / Solidity
contracts/artifacts/
contracts/cache/
contracts/out/
broadcast/
*.json
!package.json
!tsconfig.json
!public/ezkl/vk-chunks.json
!public/ezkl/vk-digest.json
!hf-space/models/stress_metrics.json

# ZK / EZKL generated files (can be large or regenerated)
*.zk
*.params
proving_key.json
verification_key.json
witness.json

# Local WASM / Model binaries (if downloaded instead of using CDN)
*.wasm
*.bin
*.weights
# MediaPipe face_mesh assets are self-hosted from public/mediapipe so the
# face scan has no runtime jsdelivr dependency. Keep them checked in.
!public/mediapipe/*.wasm
!public/mediapipe/*.data

# Python virtual environment
.venv/

# EZKL temporary test directory
public/ezkl-test/

# EZKL large regeneratable artifacts (proving key, SRS, verification key)
public/ezkl/*.key
public/ezkl/*.bytes

# Storybook build artifacts
storybook-static/
public/storybook/

# OS specific
.DS_Store
Thumbs.db
.blackboxcli/
