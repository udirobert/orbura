{
  "name": "nextjs-template",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.9",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "cleanup:demo": "bun scripts/cleanup-demo.ts",
    "sdk:sync": "rm -rf node_modules/@eazo/sdk && mkdir -p node_modules/@eazo/sdk && cp ../eazo-sdk/sdk/package.json node_modules/@eazo/sdk/ && cp -r ../eazo-sdk/sdk/dist node_modules/@eazo/sdk/dist && cp -R ../eazo-sdk/sdk/node_modules node_modules/@eazo/sdk/node_modules",
    "sdk:dev": "(cd ../eazo-sdk/sdk && npm run build) && bun run sdk:sync",
    "sdk:watch": "bun run scripts/sdk-watch.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun src/lib/db/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:drop": "drizzle-kit drop",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "bun run lint"
    ]
  },
  "dependencies": {
    "@base-ui/react": "^1.4.0",
    "@eazo/sdk": "0.19.0",
    "@ezkljs/engine": "^22.0.1",
    "@mediapipe/camera_utils": "^0.3.1632432234",
    "@mediapipe/face_mesh": "^0.4.1633559619",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tanstack/react-query": "^5.59.0",
    "@wagmi/connectors": "^8.0.15",
    "@wagmi/core": "^3.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.38.0",
    "lightningcss-darwin-arm64": "1.32.0",
    "lucide-react": "^1.8.0",
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "onnxruntime-web": "^1.18.0",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.3.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "viem": "^2.21.0",
    "wagmi": "^2.12.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.7",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
}
