# ─── Database (required for persistence) ──────────────────────────────────────
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/myapp

# ─── Auth.js (NextAuth v5) ────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=
# Public URL of the app (used for callback URLs). Must match the deployed domain.
# On Vercel this is auto-detected; set it explicitly for other hosts.
AUTH_URL=http://localhost:3000

# Email magic links (optional in dev — links are logged to the console)
# For production, use an SMTP provider (Resend, Postmark, SendGrid, etc.)
EMAIL_SERVER_HOST=
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=
EMAIL_SERVER_PASSWORD=
EMAIL_FROM=Body Debt <noreply@bodydebt.ai>

# Care Companion escalation notifications (optional)
# When set, escalations from patient check-ins are emailed to this address.
CARE_TEAM_EMAIL=

# GitHub OAuth (optional — for social login)
# Create at: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── Vercel Cron (required for daily-digest notifications) ────────────────────
# Shared secret: Vercel sends this as Authorization: Bearer <CRON_SECRET>
# when firing scheduled cron invocations. Set it in Vercel dashboard too.
CRON_SECRET=replace_with_a_long_random_string

# ─── Terra API (required for wearable integration: WHOOP, Oura, Garmin, etc.) ─
# Get these from https://tryterra.co
TERRA_DEV_ID=
TERRA_API_KEY=
TERRA_SIGNING_SECRET=

# ─── Google Fit (required for Fitbit / Android integration) ───────────────────
# Create OAuth 2.0 credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_FIT_CLIENT_ID=
GOOGLE_FIT_CLIENT_SECRET=

# ─── Blockchain / ZK (optional — SKALE Europa Testnet) ───────────────────────
# Private key for deploying contracts with Hardhat (e.g. HealthCredentialVerifier)
DEPLOYER_PRIVATE_KEY=
# Verifier contract address (set after deployment via `bun run deploy:contract`)
NEXT_PUBLIC_VERIFIER_ADDRESS=0x0000000000000000000000000000000000000000

# ─── App URL (optional — for callback redirects) ─────────────────────────────
# Public base URL. Falls back to VERCEL_URL on Vercel; uses localhost in dev.
NEXT_PUBLIC_APP_URL=

# ─── Cloud AI (optional — verdict enhancement) ─────────────────────────────
# Enable to run cloud AI verdict/prescription alongside the deterministic
# score. When disabled (default), the self-hosted QVAC pipeline runs on the
# app server and no third-party model API is used.
# NEXT_PUBLIC_ENABLE_CLOUD_VERDICT=true

# ─── QVAC self-hosted AI (optional — local model path) ───────────────────────
# Override the QVAC model path if not using the default bundled model.
# Default: Qwen3-1.7B-Instruct Q4 via @qvac/sdk registry.
# QVAC_MODEL_PATH=

# ─── Supermemory (optional — persistent agent memory) ───────────────────────
# Get your API key from https://console.supermemory.ai (cloud) or run
# `supermemory-server` locally and use the key printed on first boot.
# Cloud:  SUPERMEMORY_BASE_URL=https://api.supermemory.ai
# Local:  SUPERMEMORY_BASE_URL=http://localhost:6767
SUPERMEMORY_API_KEY=
SUPERMEMORY_BASE_URL=https://api.supermemory.ai

# ─── Eazo Platform (legacy / optional) ────────────────────────────────────────
# The app uses Auth.js (NextAuth v5) for authentication. Eazo SDK stubs are
# still present for compatibility but Eazo credentials are no longer required.
# EAZO_APP_ID=
# EAZO_PRIVATE_KEY=
# NEXT_PUBLIC_EAZO_APP_ID=
# EAZO_PLATFORM_API_BASE=
