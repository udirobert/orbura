# ─── Eazo Platform (required) ─────────────────────────────────────────────────
# Get these from https://eazo.ai
EAZO_APP_ID=
EAZO_PRIVATE_KEY=

# ─── Database (required for persistence) ──────────────────────────────────────
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/myapp

# ─── Vercel Cron (required for daily-digest notifications) ────────────────────
# Shared secret: Vercel sends this as Authorization: Bearer <CRON_SECRET>
# when firing scheduled cron invocations. Set it in Vercel dashboard too.
CRON_SECRET=replace_with_a_long_random_string

# ─── Terra API (required for wearable integration: WHOOP, Oura, Garmin, etc.) ─
# Get these from https://tryterra.co
TERRA_DEV_ID=
TERRA_API_KEY=
TERRA_SIGNING_SECRET=

# ─── Google Fit (required for Fitbit / Android integration) ───────────────────
# Create OAuth 2.0 credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_FIT_CLIENT_ID=
GOOGLE_FIT_CLIENT_SECRET=

# ─── Blockchain / ZK (optional — SKALE Europa Testnet) ───────────────────────
# Private key for deploying contracts with Hardhat (e.g. HealthCredentialVerifier)
DEPLOYER_PRIVATE_KEY=
# Verifier contract address (set after deployment via `bun run deploy:contract`)
NEXT_PUBLIC_VERIFIER_ADDRESS=0x0000000000000000000000000000000000000000

# ─── App URL (optional — for callback redirects) ─────────────────────────────
# Public base URL. Falls back to VERCEL_URL on Vercel; uses localhost in dev.
NEXT_PUBLIC_APP_URL=

# ─── Eazo Platform (optional overrides) ──────────────────────────────────────
# Override the Eazo platform base URL (defaults to https://eazo.ai)
# EAZO_PLATFORM_API_BASE=

# ─── GenAuth (optional overrides) ───────────────────────────────────────────
# Override default GenAuth App ID / domain
# NEXT_PUBLIC_GENAUTH_APP_ID=
# NEXT_PUBLIC_GENAUTH_APP_DOMAIN=

# ─── QVAC Edge AI (optional — local model path) ─────────────────────────────
# Override the QVAC model path if not using the default bundled model
# QVAC_MODEL_PATH=

# Public Eazo app ID (used client-side for share/compose)
# Usually the same value as EAZO_APP_ID but needs the NEXT_PUBLIC_ prefix
# NEXT_PUBLIC_EAZO_APP_ID=
